# Copy this file to .env and fill in real values. Never commit .env.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001
NODE_ENV=development

# --- Admin Dashboard additions ---

# Email (contact-form admin alert + visitor auto-reply). Leave unset to skip sending —
# nothing else breaks, mailService just logs a warning and marks emailStatus as false.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Shailesh Kale <you@example.com>
ADMIN_EMAIL=you@example.com

# Symmetric key used to encrypt LinkedProject.apiKey at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# GitHub integration. GITHUB_TOKEN is optional but required for the contributions
# graph (a classic PAT with no scopes is enough for public data).
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=

# LeetCode integration (unofficial GraphQL API — see leetcodeIntegrationService.js).
LEETCODE_USERNAME=your-leetcode-username

# Cron schedule (standard 5-field cron syntax) for refreshing GitHub/LeetCode
# caches + syncing linked projects. Only used on non-serverless deployments.
INTEGRATION_SYNC_CRON=0 * * * *

# Shared secret allowing POST /api/integrations/sync to be called by an external
# scheduler (e.g. Vercel Cron) without an admin JWT — send as `x-cron-secret` header.
CRON_SECRET=
